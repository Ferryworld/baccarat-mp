/* app.wxss */
page {
  background: linear-gradient(160deg, #0a1628 0%, #0f2240 60%, #071020 100%);
  min-height: 100vh;
  color: #e8d5a3;
  font-family: 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.gold-title {
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: #c9a84c;
  text-transform: uppercase;
}

.gold-divider {
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c9a84c, transparent);
  margin: 12rpx auto;
}

.card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(201, 168, 76, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

.btn-banker {
  background: linear-gradient(135deg, #c53030, #e53e3e);
  box-shadow: 0 4rpx 24rpx rgba(229, 62, 62, 0.4);
}

.btn-player {
  background: linear-gradient(135deg, #2b6cb0, #3182ce);
  box-shadow: 0 4rpx 24rpx rgba(49, 130, 206, 0.4);
}

.btn-tie {
  background: linear-gradient(135deg, #276749, #38a169);
  box-shadow: 0 4rpx 24rpx rgba(56, 161, 105, 0.4);
}

.bead {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 700;
}

.bead-B {
  background: radial-gradient(circle at 35% 35%, #fc8181, #e53e3e);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.bead-P {
  background: radial-gradient(circle at 35% 35%, #63b3ed, #3182ce);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.bead-T {
  background: radial-gradient(circle at 35% 35%, #68d391, #38a169);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.tag-high { color: #f6c90e; border-color: rgba(246, 201, 14, 0.4); background: rgba(246, 201, 14, 0.1); }
.tag-mid  { color: #68d391; border-color: rgba(104, 211, 145, 0.4); background: rgba(104, 211, 145, 0.1); }
.tag-low  { color: #a0aec0; border-color: rgba(160, 174, 192, 0.4); background: rgba(160, 174, 192, 0.1); }
