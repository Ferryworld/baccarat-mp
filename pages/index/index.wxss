/* pages/index/index.wxss */

.container {
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.header {
  padding: 20rpx 30rpx 16rpx;
  background: linear-gradient(180deg, rgba(10, 22, 40, 0.95) 0%, transparent 100%);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.shoe-badge {
  background: rgba(201, 168, 76, 0.15);
  border: 1rpx solid rgba(201, 168, 76, 0.4);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  color: #c9a84c;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #e8d5a3;
  letter-spacing: 4rpx;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 30rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  border: 1rpx solid rgba(201, 168, 76, 0.15);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-val {
  font-size: 34rpx;
  font-weight: 700;
  color: #e8d5a3;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.banker-color { color: #fc8181 !important; }
.player-color { color: #63b3ed !important; }
.tie-color    { color: #68d391 !important; }
.gold-color   { color: #fbd38d !important; }

/* ===== Card ===== */
.card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(201, 168, 76, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

.card-title {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #c9a84c;
  margin-bottom: 16rpx;
}

/* ===== Big Road ===== */
.road-scroll {
  width: 100%;
}

.road-grid {
  position: relative;
  background: rgba(0, 30, 15, 0.5);
  border-radius: 8rpx;
}

.road-cell {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.04);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.tie-badge {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  background: #38a169;
  color: #fff;
  font-size: 16rpx;
  border-radius: 6rpx 0 0 0;
  padding: 0 4rpx;
  line-height: 22rpx;
}

.road-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #444;
  font-size: 24rpx;
  text-align: center;
  white-space: nowrap;
}

/* ===== Bead ===== */
.bead {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 700;
  color: #fff;
}

.bead-B {
  background: radial-gradient(circle at 35% 35%, #fc8181, #e53e3e);
  box-shadow: 0 2rpx 12rpx rgba(229, 62, 62, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.bead-P {
  background: radial-gradient(circle at 35% 35%, #63b3ed, #3182ce);
  box-shadow: 0 2rpx 12rpx rgba(49, 130, 206, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.bead-T {
  background: radial-gradient(circle at 35% 35%, #68d391, #38a169);
  box-shadow: 0 2rpx 12rpx rgba(56, 161, 105, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* ===== Input Buttons ===== */
.input-section {
  margin: 0 24rpx 8rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.result-btn {
  flex: 1;
  height: 140rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: none;
}

.result-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.btn-main {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.btn-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.util-row {
  display: flex;
  gap: 16rpx;
}

.util-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999;
}

.util-btn:active { opacity: 0.7; }

.scan-btn {
  background: rgba(201, 168, 76, 0.12);
  border-color: rgba(201, 168, 76, 0.3);
  color: #c9a84c;
}

.danger-btn {
  background: rgba(229, 62, 62, 0.08);
  border-color: rgba(229, 62, 62, 0.2);
  color: #fc8181;
}

/* ===== Strategy ===== */
.strategy-card {
  background: rgba(0, 10, 30, 0.7);
}

.strategy-tabs {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.strat-tab {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #888;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-right: 10rpx;
}

.strat-tab-active {
  background: rgba(201, 168, 76, 0.15);
  border-color: rgba(201, 168, 76, 0.5);
  color: #c9a84c;
}

.rec-card {
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.rec-B { background: rgba(229, 62, 62, 0.1); border: 1rpx solid rgba(229, 62, 62, 0.3); }
.rec-P { background: rgba(49, 130, 206, 0.1); border: 1rpx solid rgba(49, 130, 206, 0.3); }
.rec-T { background: rgba(56, 161, 105, 0.1); border: 1rpx solid rgba(56, 161, 105, 0.3); }

.rec-bead {
  width: 96rpx;
  height: 96rpx;
  font-size: 34rpx;
  flex-shrink: 0;
}

.rec-content { flex: 1; }

.rec-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.rec-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8d5a3;
}

.conf-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid;
}

.tag-high { color: #f6c90e; border-color: rgba(246, 201, 14, 0.4); background: rgba(246, 201, 14, 0.1); }
.tag-mid  { color: #68d391; border-color: rgba(104, 211, 145, 0.4); background: rgba(104, 211, 145, 0.1); }
.tag-low  { color: #a0aec0; border-color: rgba(160, 174, 192, 0.4); background: rgba(160, 174, 192, 0.1); }

.rec-reason {
  font-size: 24rpx;
  color: #a0aec0;
  line-height: 1.6;
}

.streak-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.streak-text {
  font-size: 26rpx;
  color: #c0a87a;
}

.chop-info {
  font-size: 24rpx;
  color: #68d391;
  padding: 10rpx 16rpx;
  background: rgba(104, 211, 145, 0.08);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.disclaimer {
  font-size: 20rpx;
  color: #555;
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  line-height: 1.6;
}

/* ===== Modal ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-box {
  background: linear-gradient(180deg, #0f2240, #0a1628);
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8d5a3;
  margin-bottom: 24rpx;
  text-align: center;
}

.scan-image {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  margin-bottom: 20rpx;
}

.scan-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(201, 168, 76, 0.2);
  border-top-color: #c9a84c;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #c9a84c;
}

.scan-result { padding: 0 4rpx; }

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.result-count {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8d5a3;
}

.result-notes {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 16rpx;
}

.preview-beads {
  display: flex;
  white-space: nowrap;
  padding: 12rpx 0;
  margin-bottom: 20rpx;
}

.scan-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.scan-btn-secondary {
  flex: 1;
  height: 80rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #aaa;
}

.scan-btn-primary {
  flex: 2;
  height: 80rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #b7942a, #c9a84c);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #0a1628;
}

.modal-close {
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #666;
}

/* API Modal */
.modal-desc {
  font-size: 26rpx;
  color: #a0aec0;
  line-height: 1.8;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

.api-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #e8d5a3;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.input-placeholder { color: #555; }

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-btn-cancel {
  flex: 1;
  height: 80rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #888;
}

.modal-btn-confirm {
  flex: 2;
  height: 80rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #b7942a, #c9a84c);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #0a1628;
}
